# =============================================================================
# AI Observe Stack Environment Configuration
# =============================================================================
# Copy this file to .env and modify the values to match your environment.
#
# Usage (all-in-one with built-in Doris):
#   cp .env.example .env
#   # Edit .env with your settings
#   docker compose up -d
#
# Usage (external Doris):
#   cp .env.example .env
#   # Edit .env with your settings
#   docker compose -f docker-compose-without-doris.yaml up -d

# =============================================================================
# Doris - All-in-One Settings (docker-compose.yaml)
# =============================================================================
# These settings apply when using the built-in Doris all-in-one image.

# Doris container image
# DORIS_IMAGE=apache/doris:4.0.3-all-slim

# Doris exposed ports (host:container)
# DORIS_FE_HTTP_PORT=8030
# DORIS_FE_MYSQL_PORT=9030
# DORIS_BE_HTTP_PORT=8040

# =============================================================================
# Doris - External Connection Settings (docker-compose-without-doris.yaml)
# =============================================================================
# Configure these to connect to your existing Apache Doris instance.

# Doris FE (Frontend) HTTP endpoint for Stream Load
# Format: http://<host>:<fe_http_port>
DORIS_FE_HTTP_ENDPOINT=http://host.docker.internal:8030

# Doris FE (Frontend) MySQL protocol endpoint
# Format: <host>:<fe_mysql_port>
DORIS_FE_MYSQL_ENDPOINT=host.docker.internal:9030

# Doris authentication credentials
DORIS_USERNAME=root
DORIS_PASSWORD=

# =============================================================================
# Doris Database & Table Settings
# =============================================================================
# Database and table names for storing OpenTelemetry data.
# The tables will be auto-created by the OTel collector if they don't exist.

DORIS_DATABASE=otel
DORIS_TABLE_LOGS=otel_logs
DORIS_TABLE_TRACES=otel_traces
DORIS_TABLE_METRICS=otel_metrics

# =============================================================================
# Timezone
# =============================================================================
# Timezone used by the OTel Collector's Doris Exporter when writing timestamps.
# Doris DATETIME columns have no timezone info, so this determines how timestamps
# are stored. Set to your local timezone for Doris App plugin compatibility.
#
# Examples: UTC, Asia/Shanghai, America/New_York, Europe/London
# Reference: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
DORIS_TIMEZONE=UTC

# =============================================================================
# Grafana Settings
# =============================================================================

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
